# Required — obtain from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# Required in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=YOUR_SECRET_KEY_HERE

# Optional — defaults shown
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemma-4-31b-it:free
OPENROUTER_TIMEOUT=8
FLASK_DEBUG=false
MAX_MESSAGE_LENGTH=2000
MAX_TOKENS=512
RATE_LIMIT=20 per minute
CALENDLY_URL=https://calendly.com/muizznaveed-internetworks/30min

# ─────────────────────────────────────────────────────────────────────────────
# Redis (STRONGLY recommended for production with >1 Gunicorn worker)
# Without this, rate limiting and lead-capture sessions are per-process only,
# meaning a user hitting different workers gets different session state and
# can bypass rate limits.
# Format: redis://localhost:6379/0  or  rediss://user:pass@host:6380/0
# ─────────────────────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────────────────────────────────────
# Voice — Speech-To-Text (Whisper) + Text-To-Speech (OpenAI TTS)
# Both features require ENABLE_VOICE=true AND a valid OPENAI_API_KEY.
# When ENABLE_VOICE=false (default), the mic button shows a "coming soon" toast.
#
# Quick-start:
#   1. Get an API key from https://platform.openai.com/api-keys
#   2. Set ENABLE_VOICE=true and paste the key below
#   3. Restart the server — /voice-status will return {"voice_enabled": true}
# ─────────────────────────────────────────────────────────────────────────────
ENABLE_VOICE=true
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE

# Reserved for future alternate voice providers — NOT currently used.
# Uncomment and populate if you switch providers later.
# ELEVENLABS_API_KEY=YOUR_ELEVENLABS_KEY_HERE
# DEEPGRAM_API_KEY=YOUR_DEEPGRAM_KEY_HERE


# Lead Capture / Email Notifications
# All fields below are OPTIONAL. When SMTP is not configured, every collected
# lead is still saved locally to leads_backup.jsonl as a safety net.
#
# Gmail quick-start:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate an "App password" for "Mail"
#   4. Use that 16-character password as SMTP_PASSWORD below
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail_address@gmail.com
SMTP_PASSWORD=your_16_char_app_password_here
SMTP_FROM_EMAIL=your_gmail_address@gmail.com
LEAD_NOTIFICATION_EMAIL=muizznaveed@internetworks.io
